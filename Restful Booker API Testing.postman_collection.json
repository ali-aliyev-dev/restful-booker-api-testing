  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"token\", response.token);\r",
                  "\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token exists\", function () {\r",
                  "    pm.expect(response.token).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token is string\", function () {\r",
                  "    pm.expect(response.token).to.be.a(\"string\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token is not empty\", function () {\r",
                  "    pm.expect(response.token).to.not.be.empty;\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"username\": \"admin\",\r\n    \"password\": \"password123\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth"
              ]
            }
          },
          "response": []
        }
      ]
    },

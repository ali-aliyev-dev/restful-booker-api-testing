        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();\r",
                  "\r",
                  "pm.environment.set(\"bookingId\", response.bookingid);\r",
                  "\r",
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking ID is created\", function () {\r",
                  "    pm.expect(response.bookingid).to.not.be.undefined;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Booking ID is not null\", function () {\r",
                  "    pm.expect(response.bookingid).to.not.be.null;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Firstname is Ali\", function () {\r",
                  "    pm.expect(response.booking.firstname).to.eql(\"Ali\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Lastname is Mammadov\", function () {\r",
                  "    pm.expect(response.booking.lastname).to.eql(\"Mammadov\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"totalprice is 500\", function () {\r",
                  "    pm.expect(response.booking.totalprice).to.eql(500);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Deposit paid is true\", function () {\r",
                  "    pm.expect(response.booking.depositpaid).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"additionalneeds is Breakfast\", function () {\r",
                  "    pm.expect(response.booking.additionalneeds).to.eql(\"Breakfast\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
